# Настройка журнала мониторинга
проверяем статус, должен быть активен
sudo systemctl status systemd-journald

демонстрация логов
sudo tail -f /var/log/auth.log 

настройка фильтрации (выводит только критические ошибки системы за текущую сессию)
journalctl -p err..emerg -b


